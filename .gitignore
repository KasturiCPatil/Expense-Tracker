# Root .gitignore for monorepo

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
dist/
backend/dist/
frontend/.next/
frontend/out/

# Environment variables
.env
backend/.env
frontend/.env
frontend/.env.local

# Database
*.sqlite
*.sqlite-journal

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log
backend/storage/
/.metadata/
